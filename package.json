    "build:all": "rm -rf dist && vite build && esbuild server/index.ts --bundle --platform=node --outdir=dist/server --format=esm --packages=external && esbuild server/worker.ts --bundle --platform=node --outdir=dist/worker --format=esm --packages=external",
    "start": "node dist/server/index.js",
    "start:worker": "node dist/worker/worker.js",
    "test": "playwright test",
    "test:e2e": "playwright test"
  },
