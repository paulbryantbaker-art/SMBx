[
  {
    "id": "CONF.DEALOS.LIFECYCLE.001",
    "title": "Lifecycle trace keeps the recursive Deal OS loop portable",
    "specVersion": "DEFINITIVE.v1.0",
    "methodologyUri": "methodology://v19",
    "toolName": "compose_lifecycle_trace",
    "input": {
      "payload": {
        "targetName": "Atlas HVAC Services",
        "journey": "buy",
        "dealType": "lower middle market HVAC acquisition",
        "industry": "HVAC services",
        "jurisdiction": "US-DE",
        "purchasePriceCents": 540000000,
        "enterpriseValueCents": 540000000,
        "ebitdaCents": 82000000,
        "revenueCents": 1120000000,
        "sources": [
          { "id": "src-fin", "name": "TTM financials", "type": "financials", "hash": "sha256:fin", "citationReady": true },
          { "id": "src-legal", "name": "Draft LOI", "type": "legal", "hash": "sha256:legal", "citationReady": true },
          { "id": "src-tax", "name": "Tax returns", "type": "tax", "hash": "sha256:tax", "citationReady": true },
          { "id": "src-commercial", "name": "Customer cohort analysis", "type": "commercial", "hash": "sha256:commercial", "citationReady": true },
          { "id": "src-ops", "name": "Operations KPI pack", "type": "operations", "hash": "sha256:ops", "citationReady": true },
          { "id": "src-financing", "name": "Debt schedule", "type": "financing", "hash": "sha256:debt", "citationReady": true }
        ],
        "dealEvents": [
          { "id": "evt-ioi", "eventType": "ioi", "stage": "ioi", "label": "IOI received", "sourceRefs": ["src-legal"], "artifactRefs": [] }
        ]
      }
    },
    "expect": {
      "action": "compose_lifecycle_trace",
      "artifactPath": "result.lifecycleTrace",
      "schema": "LifecycleTrace.v0.1",
      "nextSuggestedToolsInclude": ["update_deal_payload", "compose_deal_package"],
      "takeBackArtifactsInclude": ["LifecycleTrace", "DealState", "DealPlan"],
      "fields": [
        { "path": "result.lifecycleTrace.loopContract.recursiveLoop", "includes": "update_deal_payload" },
        { "path": "result.lifecycleTrace.humanAndAgentSurfaces", "includes": "data_room" }
      ]
    }
  },
