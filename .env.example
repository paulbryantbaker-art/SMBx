# Database
DATABASE_URL=postgresql://user:password@localhost:5432/smbx
DATABASE_SSL=false

# AI APIs
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_AI_API_KEY=
OPENAI_API_KEY=sk-...

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe (subscriptions)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_SOLO=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_TEAM=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# Legacy aliases still read as fallbacks only.
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_PROFESSIONAL=price_...

# Auth
JWT_SECRET=dev-secret-change-in-production
TEST_MODE=true
DEV_NO_PAYWALL=true
DEV_ADMIN_EMAIL=pbaker@smbx.ai
DEV_ADMIN_PASSWORD=test123

# App
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:5173
# Optional comma-separated browser origins allowed to call /mcp when an Origin
# header is present. Server-side connector calls usually omit Origin.
MCP_ALLOWED_ORIGINS=
# Optional OAuth authorization-server issuer URL advertised from
# /.well-known/oauth-protected-resource/mcp. If omitted, APP_URL is advertised
# while the scoped JWT bridge remains the pilot auth path.
MCP_AUTHORIZATION_SERVER_URL=
# Optional confidential OAuth client for private ChatGPT GPT Actions testing.
# Use these as the client ID/secret in the GPT Action OAuth settings.
SMBX_GPT_ACTIONS_CLIENT_ID=
SMBX_GPT_ACTIONS_CLIENT_SECRET=
# Optional exact callback allow-list. If empty, the server still accepts
# ChatGPT callback URLs matching https://chatgpt.com/aip/*/oauth/callback and
# https://chat.openai.com/aip/*/oauth/callback for the configured client.
SMBX_GPT_ACTIONS_REDIRECT_URIS=
VITE_DEV_AUTH_BYPASS=false

# File storage — S3-compatible (AWS S3, Cloudflare R2, Backblaze B2)
# If S3_BUCKET + AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY are all set, uploads
# go to S3-compatible object storage with AES256 encryption and presigned
# 60-min download URLs. If any are missing, storageService falls back to local
# filesystem at UPLOAD_PATH. In production, use object storage or mount a
# persistent Railway volume at /data/uploads.
#
# Required IAM permissions on the bucket:
#   s3:PutObject, s3:GetObject, s3:DeleteObject, s3:ListBucket
# Bucket must be PRIVATE (block public access on). Presigned URLs handle
# browser access with 1-hour expiry.
S3_BUCKET=
S3_REGION=us-east-1
# Required for Cloudflare R2 / Backblaze B2 style endpoints, optional for AWS.
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Local filesystem fallback — only used when S3 is NOT configured
UPLOAD_PATH=./uploads
