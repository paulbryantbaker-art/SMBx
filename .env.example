# Database
DATABASE_URL=postgresql://user:password@localhost:5432/smbx

# AI APIs
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_AI_API_KEY=
OPENAI_API_KEY=sk-...

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe (subscriptions)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PROFESSIONAL=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# Auth
JWT_SECRET=dev-secret-change-in-production

# App
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:5173

# File storage — S3 + IAM
# If S3_BUCKET + AWS_ACCESS_KEY_ID are BOTH set, uploads go to S3 with AES256
# encryption and presigned 60-min download URLs. If EITHER is missing, the
# storageService falls back to local filesystem at UPLOAD_PATH (dev only —
# Railway ephemeral filesystem loses uploads on redeploy, so S3 is required
# in production).
#
# Required IAM permissions on the bucket:
#   s3:PutObject, s3:GetObject, s3:DeleteObject, s3:ListBucket
# Bucket must be PRIVATE (block public access on). Presigned URLs handle
# browser access with 1-hour expiry.
S3_BUCKET=
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Local filesystem fallback — only used when S3 is NOT configured
UPLOAD_PATH=/tmp/uploads
