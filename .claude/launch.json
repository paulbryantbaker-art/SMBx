{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5173
    },
    {
      "name": "backend",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["tsx", "server/index.ts"],
      "port": 3000
    },
    {
      "name": "frontend-realauth",
      "runtimeExecutable": "env",
      "runtimeArgs": ["VITE_DEV_AUTH_BYPASS=false", "npx", "vite", "--port", "5175", "--strictPort"],
      "port": 5175
    }
  ]
}
